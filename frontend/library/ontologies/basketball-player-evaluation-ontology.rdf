        <rdfs:range rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Team"/>
        <rdfs:comment>A season performance record is associated with a specific team stint.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>season-performance</ont:fromEntityId>
        <ont:toEntityId>team</ont:toEntityId>
