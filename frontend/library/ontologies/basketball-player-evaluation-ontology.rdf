        <rdfs:comment>A player can sign multiple contracts over time.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>player</ont:fromEntityId>
        <ont:toEntityId>contract</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/contract-with-team">
        <rdfs:label>withTeam</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Contract"/>
        <rdfs:range rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Team"/>
