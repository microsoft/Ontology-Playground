        <rdfs:range rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Season-performance"/>
        <rdfs:comment>A player can have multiple season performance records.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>player</ont:fromEntityId>
        <ont:toEntityId>season-performance</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/season-performance-for-team">
        <rdfs:label>forTeam</rdfs:label>
