<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/basketball-player-evaluation-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/basketball-player-evaluation-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/">
        <rdfs:label>Basketball Player Evaluation Ontology</rdfs:label>
        <rdfs:comment>A practical ontology draft for modeling basketball players, their physical profiles, tactical roles, skill assessments, performance metrics, contracts, awards, injuries, and commercial relationships.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Player">
        <rdfs:label>Player</rdfs:label>
        <rdfs:comment>A basketball player as the core person entity being evaluated across physical, tactical, performance, economic, and narrative dimensions.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#2563EB</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Team">
        <rdfs:label>Team</rdfs:label>
        <rdfs:comment>A basketball team or franchise associated with players through contracts, draft events, and season performance.</rdfs:comment>
        <ont:icon>🛡️</ont:icon>
        <ont:color>#D97706</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment">
        <rdfs:label>SkillAssessment</rdfs:label>
        <rdfs:comment>A scouting or analytical assessment of a player&apos;s role, archetype, and basketball skill proficiency at a point in time.</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#10B981</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Injury-record">
        <rdfs:label>InjuryRecord</rdfs:label>
        <rdfs:comment>A record of a player&apos;s injury event, affected body part, severity, and missed time.</rdfs:comment>
        <ont:icon>🩺</ont:icon>
        <ont:color>#EF4444</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Season-performance">
        <rdfs:label>SeasonPerformance</rdfs:label>
        <rdfs:comment>A season-level record of a player&apos;s box score and advanced performance metrics.</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#8B5CF6</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Contract">
        <rdfs:label>Contract</rdfs:label>
        <rdfs:comment>A player contract record containing salary, duration, and option structure.</rdfs:comment>
        <ont:icon>📄</ont:icon>
        <ont:color>#06B6D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Award">
        <rdfs:label>Award</rdfs:label>
        <rdfs:comment>An accolade or achievement record associated with a player for a season or event.</rdfs:comment>
        <ont:icon>🏆</ont:icon>
        <ont:color>#EAB308</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/Brand">
        <rdfs:label>Brand</rdfs:label>
        <rdfs:comment>A commercial brand associated with a player through sponsorship or endorsement.</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#EC4899</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_playerId">
        <rdfs:label>playerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier for the player.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_fullName">
        <rdfs:label>fullName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Player full name.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_nationality">
        <rdfs:label>nationality</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Player nationality or national team identity.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_heightCm">
        <rdfs:label>heightCm</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Player height.</rdfs:comment>
        <ont:unit>cm</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_weightKg">
        <rdfs:label>weightKg</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Player weight.</rdfs:comment>
        <ont:unit>kg</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_wingspanCm">
        <rdfs:label>wingspanCm</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Player wingspan.</rdfs:comment>
        <ont:unit>cm</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_standingReachCm">
        <rdfs:label>standingReachCm</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Player standing reach.</rdfs:comment>
        <ont:unit>cm</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_verticalLeapCm">
        <rdfs:label>verticalLeapCm</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Vertical jump measurement.</rdfs:comment>
        <ont:unit>cm</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_agilityScore">
        <rdfs:label>agilityScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Agility rating or test result.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_sprintSpeedMps">
        <rdfs:label>sprintSpeedMps</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Sprint speed measurement.</rdfs:comment>
        <ont:unit>m/s</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_coreStrengthScore">
        <rdfs:label>coreStrengthScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Core strength rating.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_durabilityScore">
        <rdfs:label>durabilityScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Derived durability rating influenced by injury history.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_socialFollowers">
        <rdfs:label>socialFollowers</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Approximate social media follower count.</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player_jerseySalesRank">
        <rdfs:label>jerseySalesRank</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Jersey sales ranking in the relevant market.</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/team_teamId">
        <rdfs:label>teamId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Team"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier for the team.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/team_teamName">
        <rdfs:label>teamName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Team"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Official team name.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/team_teamAbbreviation">
        <rdfs:label>teamAbbreviation</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Team"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Short team code or abbreviation.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/team_league">
        <rdfs:label>league</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Team"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>League in which the team competes.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_assessmentId">
        <rdfs:label>assessmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier for the skill assessment.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_assessmentDate">
        <rdfs:label>assessmentDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date of the assessment.</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_primaryTraditionalPosition">
        <rdfs:label>primaryTraditionalPosition</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Primary traditional basketball position.</rdfs:comment>
        <ont:enumValues>PG,SG,SF,PF,C</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_primaryArchetype">
        <rdfs:label>primaryArchetype</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Primary modern role-based archetype.</rdfs:comment>
        <ont:enumValues>3&amp;D,Slasher,Stretch Big,Playmaking Hub,Other</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_spotUpShootingScore">
        <rdfs:label>spotUpShootingScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Spot-up shooting proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_pullUpShootingScore">
        <rdfs:label>pullUpShootingScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Pull-up shooting proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_offScreenShootingScore">
        <rdfs:label>offScreenShootingScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Off-screen shooting proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_ballHandlingScore">
        <rdfs:label>ballHandlingScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Ball handling proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_postUpScore">
        <rdfs:label>postUpScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Post-up skill proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_passingSenseScore">
        <rdfs:label>passingSenseScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Passing sense and creation ability.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_onBallDefenseScore">
        <rdfs:label>onBallDefenseScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>On-ball defense proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_offBallDefenseScore">
        <rdfs:label>offBallDefenseScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Off-ball or help defense proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_switchDefenseScore">
        <rdfs:label>switchDefenseScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Ability to defend switches across matchups.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_boxOutReboundingScore">
        <rdfs:label>boxOutReboundingScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Box-out and rebounding technique proficiency.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_basketballIqScore">
        <rdfs:label>basketballIqScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Basketball IQ rating.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_courtVisionScore">
        <rdfs:label>courtVisionScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Court vision rating.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_clutchFocusScore">
        <rdfs:label>clutchFocusScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Concentration and composure in clutch situations.</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/skill-assessment_roleNotes">
        <rdfs:label>roleNotes</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Optional notes about role fit or tactical usage.</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/injury-record_injuryId">
        <rdfs:label>injuryId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Injury-record"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique identifier for the injury record.</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/injury-record_bodyPart">
        <rdfs:label>bodyPart</rdfs:label>
