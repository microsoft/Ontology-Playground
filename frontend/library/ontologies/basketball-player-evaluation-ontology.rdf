    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player-has-skill-assessment">
        <rdfs:label>hasSkillAssessment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Skill-assessment"/>
        <rdfs:comment>A player can have multiple skill assessments over time.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>player</ont:fromEntityId>
        <ont:toEntityId>skill-assessment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player-has-injury-record">
        <rdfs:label>hasInjuryRecord</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Injury-record"/>
        <rdfs:comment>A player can have multiple injury records across a career.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>player</ont:fromEntityId>
        <ont:toEntityId>injury-record</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player-has-season-performance">
