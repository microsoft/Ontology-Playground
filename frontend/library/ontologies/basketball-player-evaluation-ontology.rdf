    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player-received-award">
        <rdfs:label>receivedAward</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
        <rdfs:range rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Award"/>
        <rdfs:comment>A player can receive multiple awards or accolades.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>player</ont:fromEntityId>
        <ont:toEntityId>award</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/basketball-player-evaluation-ontology/player-sponsored-by">
        <rdfs:label>sponsoredBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/basketball-player-evaluation-ontology/Player"/>
