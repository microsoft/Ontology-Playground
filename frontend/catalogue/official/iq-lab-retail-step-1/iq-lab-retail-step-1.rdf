<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/">

    <owl:Ontology rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/">
        <rdfs:label>Retail Supply Chain — Step 1: Core Commerce</rdfs:label>
        <rdfs:comment>Customer, Order, Product — the foundational entities</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer">
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>The buyer associated with an order</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order">
        <rdfs:label>Order</rdfs:label>
        <rdfs:comment>A customer purchase transaction</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Product">
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>Items available for sale</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/customer_customerId">
        <rdfs:label>customerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/customer_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/customer_email">
        <rdfs:label>email</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/customer_loyaltyTier">
        <rdfs:label>loyaltyTier</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/customer_lifetimeValue">
        <rdfs:label>lifetimeValue</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/order_orderId">
        <rdfs:label>orderId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/order_orderDate">
        <rdfs:label>orderDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/order_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/order_totalAmount">
        <rdfs:label>totalAmount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/product_productId">
        <rdfs:label>productId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/product_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/product_unitCost">
        <rdfs:label>unitCost</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/product_discountPercent">
        <rdfs:label>discountPercent</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Product"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/order-placedby-customer">
        <rdfs:label>OrderPlacedByCustomer</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Customer"/>
        <rdfs:comment>Which customer placed the order</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>customer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/order-contains-product">
        <rdfs:label>OrderContainsProduct</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-1-core-commerce/Product"/>
        <rdfs:comment>Products included in the order</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
