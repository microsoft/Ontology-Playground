<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/retail-supply-chain-step-6-complete-model/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/retail-supply-chain-step-6-complete-model/">

    <owl:Ontology rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/">
        <rdfs:label>Retail Supply Chain — Step 6: Complete Model</rdfs:label>
        <rdfs:comment>Promotion and Return complete the full retail supply chain ontology</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Customer">
        <rdfs:label>Customer</rdfs:label>
        <rdfs:comment>The buyer associated with an order</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Order">
        <rdfs:label>Order</rdfs:label>
        <rdfs:comment>A customer purchase transaction</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Product">
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>Items available for sale</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Orderline">
        <rdfs:label>OrderLine</rdfs:label>
        <rdfs:comment>Individual line items within an order</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Productcategory">
        <rdfs:label>ProductCategory</rdfs:label>
        <rdfs:comment>Groupings of related products</rdfs:comment>
        <ont:icon>🏷️</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Region">
        <rdfs:label>Region</rdfs:label>
        <rdfs:comment>Geographic areas containing stores and warehouses</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#E74C3C</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Store">
        <rdfs:label>Store</rdfs:label>
        <rdfs:comment>Retail locations where orders originate</rdfs:comment>
        <ont:icon>🏪</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Shipment">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>Delivery records linking orders to carriers</rdfs:comment>
        <ont:icon>🚚</ont:icon>
        <ont:color>#0099BC</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Carrier">
        <rdfs:label>Carrier</rdfs:label>
        <rdfs:comment>Logistics providers handling shipments</rdfs:comment>
        <ont:icon>✈️</ont:icon>
        <ont:color>#7A7574</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Warehouse">
        <rdfs:label>Warehouse</rdfs:label>
        <rdfs:comment>Fulfillment centers that ship orders</rdfs:comment>
        <ont:icon>🏭</ont:icon>
        <ont:color>#2D7D9A</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Inventory">
        <rdfs:label>Inventory</rdfs:label>
        <rdfs:comment>Stock levels at warehouses</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#486860</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Forecast">
        <rdfs:label>Forecast</rdfs:label>
        <rdfs:comment>Predicted demand for products</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#B4009E</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Demandsignal">
        <rdfs:label>DemandSignal</rdfs:label>
        <rdfs:comment>Real-time indicators of customer demand</rdfs:comment>
        <ont:icon>📡</ont:icon>
        <ont:color>#005A9E</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Promotion">
        <rdfs:label>Promotion</rdfs:label>
        <rdfs:comment>Marketing campaigns affecting product sales</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#C239B3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Return">
        <rdfs:label>Return</rdfs:label>
        <rdfs:comment>Returned items linked back to orders</rdfs:comment>
        <ont:icon>🔄</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/customer_customerId">
        <rdfs:label>customerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-6-complete-model/Customer"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-6-complete-model/customer_name">
