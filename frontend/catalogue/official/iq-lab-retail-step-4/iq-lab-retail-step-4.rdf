    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/order-placedby-customer">
        <rdfs:label>OrderPlacedByCustomer</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Customer"/>
        <rdfs:comment>Which customer placed the order</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>customer</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/order-contains-product">
        <rdfs:label>OrderContainsProduct</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Product"/>
        <rdfs:comment>Products included in the order</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/order-has-lineitem">
        <rdfs:label>OrderHasLineItem</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Orderline"/>
        <rdfs:comment>Line items within an order</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>orderline</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/orderline-refs-product">
        <rdfs:label>OrderLineReferencesProduct</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Orderline"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Product"/>
        <rdfs:comment>Which product this line item refers to</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>orderline</ont:fromEntityId>
        <ont:toEntityId>product</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/product-in-category">
        <rdfs:label>ProductInCategory</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Product"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Productcategory"/>
        <rdfs:comment>Which category a product belongs to</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>product</ont:fromEntityId>
        <ont:toEntityId>productcategory</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/order-to-region">
        <rdfs:label>OrderFulfilledToRegion</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Order"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Region"/>
        <rdfs:comment>Where the order was fulfilled</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>region</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/store-in-region">
        <rdfs:label>StoreInRegion</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Store"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Region"/>
        <rdfs:comment>Which region a store is located in</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>store</ont:fromEntityId>
        <ont:toEntityId>region</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/shipment-fulfills-order">
        <rdfs:label>ShipmentFulfillsOrder</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Shipment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Order"/>
        <rdfs:comment>Which order a shipment fulfills</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>order</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/shipment-by-carrier">
        <rdfs:label>ShipmentByCarrier</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Shipment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Carrier"/>
        <rdfs:comment>Which carrier handles the shipment</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>carrier</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/shipment-from-warehouse">
        <rdfs:label>ShipmentDepartedFromWarehouse</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Shipment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/retail-supply-chain-step-4-fulfillment-logistics/Warehouse"/>
        <rdfs:comment>Which warehouse the shipment departed from</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>warehouse</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
