<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/devops-value-stream-release-intelligence/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/devops-value-stream-release-intelligence/">

    <owl:Ontology rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/">
        <rdfs:label>DevOps Value Stream &amp; Release Intelligence</rdfs:label>
        <rdfs:comment>Models the full software delivery chain — from feature request through work items, builds, and releases to production incidents and post-mortems — enabling AI agents to trace exactly which feature caused a production failure and who is accountable.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest">
        <rdfs:label>FeatureRequest</rdfs:label>
        <rdfs:comment>A business-level request for new capability or change</rdfs:comment>
        <ont:icon>💡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem">
        <rdfs:label>WorkItem</rdfs:label>
        <rdfs:comment>A discrete unit of engineering work implementing part of a feature</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent">
        <rdfs:label>ServiceComponent</rdfs:label>
        <rdfs:comment>A discrete service or module within the system architecture</rdfs:comment>
        <ont:icon>⚙️</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline">
        <rdfs:label>BuildPipeline</rdfs:label>
        <rdfs:comment>A CI/CD pipeline run that compiles, tests, and packages code</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#CA5010</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease">
        <rdfs:label>DeploymentRelease</rdfs:label>
        <rdfs:comment>A versioned deployment event pushing work items into a target environment</rdfs:comment>
        <ont:icon>🚀</ont:icon>
        <ont:color>#038387</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/Incident">
        <rdfs:label>Incident</rdfs:label>
        <rdfs:comment>A production failure or degradation event impacting users or SLA commitments</rdfs:comment>
        <ont:icon>🚨</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem">
        <rdfs:label>PostMortem</rdfs:label>
        <rdfs:comment>A structured retrospective documenting root cause and prevention actions for a resolved incident</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/featureRequest_featureId">
        <rdfs:label>featureId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique feature request identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/featureRequest_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Short descriptive title of the feature</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/featureRequest_businessPriority">
        <rdfs:label>businessPriority</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Business priority</rdfs:comment>
        <ont:enumValues>Critical,High,Medium,Low</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/featureRequest_requestedBy">
        <rdfs:label>requestedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Stakeholder or team that raised the request</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/featureRequest_targetReleaseVersion">
        <rdfs:label>targetReleaseVersion</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Planned release version</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/featureRequest_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current lifecycle status</rdfs:comment>
        <ont:enumValues>Backlog,In Progress,Released,Cancelled</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workItem_workItemId">
        <rdfs:label>workItemId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique work item identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workItem_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of engineering work</rdfs:comment>
        <ont:enumValues>Story,Bug,Task,Hotfix</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workItem_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Work item title</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workItem_assignee">
        <rdfs:label>assignee</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Engineer assigned to this work item</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workItem_sprintName">
        <rdfs:label>sprintName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Sprint in which this work item was completed</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workItem_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current work item status</rdfs:comment>
        <ont:enumValues>Todo,In Progress,Code Review,Done</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/serviceComponent_componentId">
        <rdfs:label>componentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique service component identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/serviceComponent_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Service or component name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/serviceComponent_owningTeam">
        <rdfs:label>owningTeam</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Team responsible for this component</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/serviceComponent_tier">
        <rdfs:label>tier</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Architectural tier</rdfs:comment>
        <ont:enumValues>Frontend,Backend,Data,Infrastructure,ML</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/serviceComponent_criticalityLevel">
        <rdfs:label>criticalityLevel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Business criticality if this component fails</rdfs:comment>
        <ont:enumValues>Critical,High,Medium,Low</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/serviceComponent_language">
        <rdfs:label>language</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Primary programming language or framework</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/buildPipeline_buildId">
        <rdfs:label>buildId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique build run identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/buildPipeline_branch">
        <rdfs:label>branch</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Source branch that triggered the build</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/buildPipeline_triggeredBy">
        <rdfs:label>triggeredBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Person or event that initiated the build</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/buildPipeline_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Build pipeline outcome</rdfs:comment>
        <ont:enumValues>Running,Passed,Failed,Cancelled</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/buildPipeline_durationSeconds">
        <rdfs:label>durationSeconds</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Total build duration</rdfs:comment>
        <ont:unit>seconds</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/buildPipeline_failedStage">
        <rdfs:label>failedStage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Pipeline stage where the failure occurred</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/deploymentRelease_releaseId">
        <rdfs:label>releaseId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique release identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/deploymentRelease_version">
        <rdfs:label>version</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Semantic version of the release</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/deploymentRelease_environment">
        <rdfs:label>environment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Target deployment environment</rdfs:comment>
        <ont:enumValues>Development,Staging,Production</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/deploymentRelease_deployedAt">
        <rdfs:label>deployedAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Timestamp when the deployment completed</rdfs:comment>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/deploymentRelease_deployedBy">
        <rdfs:label>deployedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Engineer or automation that executed the deployment</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/deploymentRelease_rollbackAvailable">
        <rdfs:label>rollbackAvailable</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>Whether a one-click rollback is available</rdfs:comment>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_incidentId">
        <rdfs:label>incidentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique incident identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_severity">
        <rdfs:label>severity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Incident severity</rdfs:comment>
        <ont:enumValues>P1,P2,P3,P4</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Short description of the failure</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_detectedAt">
        <rdfs:label>detectedAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>Timestamp when the incident was first detected</rdfs:comment>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current incident status</rdfs:comment>
        <ont:enumValues>Active,Mitigating,Resolved</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_affectedUsers">
        <rdfs:label>affectedUsers</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Estimated number of users impacted</rdfs:comment>
        <ont:unit>users</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postMortem_postMortemId">
        <rdfs:label>postMortemId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique post-mortem document identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postMortem_rootCause">
        <rdfs:label>rootCause</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Identified root cause of the incident</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postMortem_contributingFactors">
        <rdfs:label>contributingFactors</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Secondary factors that enabled or worsened the incident</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postMortem_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Post-mortem document status</rdfs:comment>
        <ont:enumValues>Draft,In Review,Published</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postMortem_actionItemCount">
        <rdfs:label>actionItemCount</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Number of prevention action items generated</rdfs:comment>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postMortem_publishedAt">
        <rdfs:label>publishedAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>Date the post-mortem was formally published</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/feature_decomposes_into_workitem">
        <rdfs:label>decomposesInto</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/FeatureRequest"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:comment>A feature request is broken down into one or more discrete work items</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>featureRequest</ont:fromEntityId>
        <ont:toEntityId>workItem</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workitem_modifies_component">
        <rdfs:label>modifies</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:comment>A work item changes code within a specific service component</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>workItem</ont:fromEntityId>
        <ont:toEntityId>serviceComponent</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/workitem_bundled_in_release">
        <rdfs:label>bundledIn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/WorkItem"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:comment>Work items are bundled together and shipped as a deployment release</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>workItem</ont:fromEntityId>
        <ont:toEntityId>deploymentRelease</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/build_validates_release">
        <rdfs:label>validates</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/BuildPipeline"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:comment>A build pipeline run validates and produces the artifacts for a release</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>buildPipeline</ont:fromEntityId>
        <ont:toEntityId>deploymentRelease</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/release_triggers_incident">
        <rdfs:label>triggers</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/DeploymentRelease"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:comment>A deployment release introduces changes that trigger a production incident</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>deploymentRelease</ont:fromEntityId>
        <ont:toEntityId>incident</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/incident_impacts_component">
        <rdfs:label>impacts</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/ServiceComponent"/>
        <rdfs:comment>A production incident degrades or takes down one or more service components</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>incident</ont:fromEntityId>
        <ont:toEntityId>serviceComponent</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/devops-value-stream-release-intelligence/postmortem_documents_incident">
        <rdfs:label>documents</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/PostMortem"/>
        <rdfs:range rdf:resource="http://example.org/ontology/devops-value-stream-release-intelligence/Incident"/>
        <rdfs:comment>A post-mortem documents the root cause and prevention actions for a resolved incident</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>postMortem</ont:fromEntityId>
        <ont:toEntityId>incident</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
