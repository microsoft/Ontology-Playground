<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/hr-system/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/hr-system/">

    <owl:Ontology rdf:about="http://example.org/ontology/hr-system/">
        <rdfs:label>HR System</rdfs:label>
        <rdfs:comment>Human resources ontology for organizational structure, staffing, and performance management.</rdfs:comment>
    </owl:Ontology>

    <!-- Entity Types -->
    <owl:Class rdf:about="http://example.org/ontology/hr-system/Employee">
        <rdfs:label>Employee</rdfs:label>
        <rdfs:comment>Person employed by the organization.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/hr-system/Department">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>Organizational unit responsible for a business function.</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/hr-system/Position">
        <rdfs:label>Position</rdfs:label>
        <rdfs:comment>Defined role within the organization.</rdfs:comment>
        <ont:icon>💼</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/hr-system/Assignment">
        <rdfs:label>Assignment</rdfs:label>
        <rdfs:comment>Employee assignment to a department and position over a period of time.</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#00B7C3</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/hr-system/PerformanceReview">
        <rdfs:label>PerformanceReview</rdfs:label>
        <rdfs:comment>Periodic evaluation of employee performance.</rdfs:comment>
        <ont:icon>⭐</ont:icon>
        <ont:color>#8764B8</ont:color>
    </owl:Class>

    <!-- Data Properties: Employee -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/employee_employeeId">
        <rdfs:label>employeeId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/employee_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/employee_hireDate">
        <rdfs:label>hireDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/employee_employmentStatus">
        <rdfs:label>employmentStatus</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
        <ont:enumValues>active,onLeave,terminated</ont:enumValues>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/employee_jobLevel">
        <rdfs:label>jobLevel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
        <ont:enumValues>junior,mid,senior,lead,manager,director</ont:enumValues>
    </owl:DatatypeProperty>

    <!-- Data Properties: Department -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/department_departmentId">
        <rdfs:label>departmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/department_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/department_budget">
        <rdfs:label>budget</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/department_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Department"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
        <ont:enumValues>active,inactive</ont:enumValues>
    </owl:DatatypeProperty>

    <!-- Data Properties: Position -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/position_positionId">
        <rdfs:label>positionId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Position"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/position_title">
        <rdfs:label>title</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Position"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/position_level">
        <rdfs:label>level</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Position"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
        <ont:enumValues>individualContributor,teamLead,manager,director</ont:enumValues>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/position_salaryBand">
        <rdfs:label>salaryBand</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Position"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Data Properties: Assignment -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/assignment_assignmentId">
        <rdfs:label>assignmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/assignment_startDate">
        <rdfs:label>startDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/assignment_endDate">
        <rdfs:label>endDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/assignment_isPrimary">
        <rdfs:label>isPrimary</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Data Properties: PerformanceReview -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/performanceReview_reviewId">
        <rdfs:label>reviewId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/PerformanceReview"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/performanceReview_reviewPeriod">
        <rdfs:label>reviewPeriod</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/PerformanceReview"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/performanceReview_rating">
        <rdfs:label>rating</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/PerformanceReview"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
        <ont:enumValues>below,meets,exceeds,outstanding</ont:enumValues>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/hr-system/performanceReview_reviewDate">
        <rdfs:label>reviewDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/PerformanceReview"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Object Properties -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/hr-system/employee_has_assignment">
        <rdfs:label>has_assignment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:comment>Assignments associated with an employee.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>assignment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/hr-system/assignment_for_department">
        <rdfs:label>for_department</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/hr-system/Department"/>
        <rdfs:comment>Department attached to an assignment.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>assignment</ont:fromEntityId>
        <ont:toEntityId>department</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/hr-system/assignment_for_position">
        <rdfs:label>for_position</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Assignment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/hr-system/Position"/>
        <rdfs:comment>Position attached to an assignment.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>assignment</ont:fromEntityId>
        <ont:toEntityId>position</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/hr-system/employee_has_review">
        <rdfs:label>has_review</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/hr-system/Employee"/>
        <rdfs:range rdf:resource="http://example.org/ontology/hr-system/PerformanceReview"/>
        <rdfs:comment>Performance reviews recorded for an employee.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>employee</ont:fromEntityId>
        <ont:toEntityId>performanceReview</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
