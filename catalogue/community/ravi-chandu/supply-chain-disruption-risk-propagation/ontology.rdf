<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/supply-chain-disruption-risk-propagation/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/supply-chain-disruption-risk-propagation/">

    <owl:Ontology rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/">
        <rdfs:label>Supply Chain Disruption &amp; Risk Propagation</rdfs:label>
        <rdfs:comment>Models how a disruption to one supplier cascades through components and product lines, enabling AI to recommend mitigation before the impact reaches customers.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier">
        <rdfs:label>Supplier</rdfs:label>
        <rdfs:comment>External company that provides raw materials or components</rdfs:comment>
        <ont:icon>🏭</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component">
        <rdfs:label>Component</rdfs:label>
        <rdfs:comment>A part, material, or sub-assembly sourced from one or more suppliers</rdfs:comment>
        <ont:icon>🔩</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine">
        <rdfs:label>ProductLine</rdfs:label>
        <rdfs:comment>A group of finished products that share one or more common components</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent">
        <rdfs:label>DisruptionEvent</rdfs:label>
        <rdfs:comment>An event that interrupts or threatens normal supply from one or more suppliers</rdfs:comment>
        <ont:icon>⚠️</ont:icon>
        <ont:color>#D13438</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment">
        <rdfs:label>RiskAssessment</rdfs:label>
        <rdfs:comment>An analysis of the business impact when a disruption affects the supply chain</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction">
        <rdfs:label>MitigationAction</rdfs:label>
        <rdfs:comment>A concrete step taken to reduce or eliminate the impact of a supply disruption</rdfs:comment>
        <ont:icon>🛡️</ont:icon>
        <ont:color>#008575</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier">
        <rdfs:label>AlternativeSupplier</rdfs:label>
        <rdfs:comment>A qualified backup supplier capable of substituting for a disrupted primary supplier</rdfs:comment>
        <ont:icon>🔄</ont:icon>
        <ont:color>#CA5010</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_supplierId">
        <rdfs:label>supplierId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique supplier identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Supplier company name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Country of operation</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_tier">
        <rdfs:label>tier</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Supply chain tier</rdfs:comment>
        <ont:enumValues>Tier 1,Tier 2,Tier 3</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_reliabilityScore">
        <rdfs:label>reliabilityScore</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Historical on-time delivery score (0–100)</rdfs:comment>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_singleSourced">
        <rdfs:label>singleSourced</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <rdfs:comment>True if no approved alternative exists</rdfs:comment>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_componentId">
        <rdfs:label>componentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique component identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Component name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_category">
        <rdfs:label>category</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Component category</rdfs:comment>
        <ont:enumValues>Electronic,Mechanical,Chemical,Packaging,Raw Material</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_daysOfSupplyOnHand">
        <rdfs:label>daysOfSupplyOnHand</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Current inventory buffer in days</rdfs:comment>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_leadTimeDays">
        <rdfs:label>leadTimeDays</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Typical replenishment lead time</rdfs:comment>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_criticalityLevel">
        <rdfs:label>criticalityLevel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Impact level if this component is unavailable</rdfs:comment>
        <ont:enumValues>Critical,High,Medium,Low</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/productLine_productLineId">
        <rdfs:label>productLineId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique product line identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/productLine_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Product line name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/productLine_annualRevenue">
        <rdfs:label>annualRevenue</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Annual revenue attributed to this product line</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/productLine_marketSegment">
        <rdfs:label>marketSegment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Target market segment</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/productLine_productionStatus">
        <rdfs:label>productionStatus</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current production status</rdfs:comment>
        <ont:enumValues>Active,At Risk,Halted,Discontinued</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruptionEvent_eventId">
        <rdfs:label>eventId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique event identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruptionEvent_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Category of disruption</rdfs:comment>
        <ont:enumValues>Natural Disaster,Geopolitical,Financial,Logistics,Quality Recall,Pandemic,Cyber Attack</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruptionEvent_severity">
        <rdfs:label>severity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Severity of the disruption</rdfs:comment>
        <ont:enumValues>Critical,High,Medium,Low</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruptionEvent_startDate">
        <rdfs:label>startDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <rdfs:comment>When the disruption began</rdfs:comment>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruptionEvent_estimatedDurationDays">
        <rdfs:label>estimatedDurationDays</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Expected duration of the disruption</rdfs:comment>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruptionEvent_region">
        <rdfs:label>region</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Geographic region affected</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/riskAssessment_assessmentId">
        <rdfs:label>assessmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique assessment identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/riskAssessment_assessedDate">
        <rdfs:label>assessedDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <rdfs:comment>When the assessment was performed</rdfs:comment>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/riskAssessment_revenueAtRisk">
        <rdfs:label>revenueAtRisk</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Estimated revenue impacted if no action taken</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/riskAssessment_timeToImpactDays">
        <rdfs:label>timeToImpactDays</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Days until production is affected if supply is not restored</rdfs:comment>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/riskAssessment_confidenceLevel">
        <rdfs:label>confidenceLevel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Confidence in the assessment accuracy</rdfs:comment>
        <ont:enumValues>High,Medium,Low</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/riskAssessment_recommendedAction">
        <rdfs:label>recommendedAction</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Top recommended response</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/mitigationAction_actionId">
        <rdfs:label>actionId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique action identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/mitigationAction_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Type of mitigation</rdfs:comment>
        <ont:enumValues>Activate Alternative Supplier,Increase Safety Stock,Redesign Component,Reduce Production,Expedite Shipment,Customer Communication</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/mitigationAction_status">
        <rdfs:label>status</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Current action status</rdfs:comment>
        <ont:enumValues>Proposed,Approved,In Progress,Completed,Cancelled</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/mitigationAction_estimatedCost">
        <rdfs:label>estimatedCost</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Estimated cost to execute</rdfs:comment>
        <ont:unit>USD</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/mitigationAction_leadTimeSavedDays">
        <rdfs:label>leadTimeSavedDays</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Days of disruption impact avoided by this action</rdfs:comment>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/alternativeSupplier_altSupplierId">
        <rdfs:label>altSupplierId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Unique alternative supplier identifier</rdfs:comment>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/alternativeSupplier_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Alternative supplier company name</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/alternativeSupplier_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Country of operation</rdfs:comment>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/alternativeSupplier_qualificationStatus">
        <rdfs:label>qualificationStatus</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <rdfs:comment>Supplier qualification status</rdfs:comment>
        <ont:enumValues>Pre-qualified,Approved,Pending Audit,Not Qualified</ont:enumValues>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/alternativeSupplier_capacityAvailable">
        <rdfs:label>capacityAvailable</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <rdfs:comment>Available monthly production capacity</rdfs:comment>
        <ont:unit>units/month</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/alternativeSupplier_pricePremiumPercent">
        <rdfs:label>pricePremiumPercent</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <rdfs:comment>Cost premium vs primary supplier</rdfs:comment>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/supplier_supplies_component">
        <rdfs:label>supplies</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:comment>A supplier provides one or more components to the operation</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>supplier</ont:fromEntityId>
        <ont:toEntityId>component</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/component_usedin_productline">
        <rdfs:label>usedIn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Component"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/ProductLine"/>
        <rdfs:comment>A component is incorporated into one or more product lines</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>component</ont:fromEntityId>
        <ont:toEntityId>productLine</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruption_affects_supplier">
        <rdfs:label>affects</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:comment>A disruption event impacts the supply capability of a supplier</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>disruptionEvent</ont:fromEntityId>
        <ont:toEntityId>supplier</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/disruption_triggers_assessment">
        <rdfs:label>triggers</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/DisruptionEvent"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:comment>A disruption event causes one or more risk assessments to be performed</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>disruptionEvent</ont:fromEntityId>
        <ont:toEntityId>riskAssessment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/assessment_recommends_mitigation">
        <rdfs:label>recommends</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/RiskAssessment"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:comment>A risk assessment drives specific mitigation actions</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>riskAssessment</ont:fromEntityId>
        <ont:toEntityId>mitigationAction</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/mitigation_activates_altsupplier">
        <rdfs:label>activates</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/MitigationAction"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:comment>A mitigation action may bring alternative suppliers into production</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>mitigationAction</ont:fromEntityId>
        <ont:toEntityId>alternativeSupplier</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/supply-chain-disruption-risk-propagation/altsupplier_canreplace_supplier">
        <rdfs:label>canReplace</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/AlternativeSupplier"/>
        <rdfs:range rdf:resource="http://example.org/ontology/supply-chain-disruption-risk-propagation/Supplier"/>
        <rdfs:comment>An alternative supplier is qualified to substitute for a primary supplier</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>alternativeSupplier</ont:fromEntityId>
        <ont:toEntityId>supplier</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
