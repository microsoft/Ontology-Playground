<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/discord-server-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/discord-server-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/discord-server-ontology/">
        <rdfs:label>Discord Server Ontology</rdfs:label>
        <rdfs:comment>An ontology representing the Fabric Community Discord. </rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-11">
        <rdfs:label>Reaction</rdfs:label>
        <rdfs:comment>An emoji response attached to a message</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-10">
        <rdfs:label>Thread</rdfs:label>
        <rdfs:comment>A scoped sub-conversation within a channel</rdfs:comment>
        <ont:icon>📁</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-9">
        <rdfs:label>Moderation_Action</rdfs:label>
        <rdfs:comment>A logged enforcement action (warn, mute, ban, kick)</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-8">
        <rdfs:label>Event</rdfs:label>
        <rdfs:comment>A scheduled community activity (voice hangout, Q&amp;A, etc.)</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-7">
        <rdfs:label>Bot</rdfs:label>
        <rdfs:comment>An automated agent operating in the server</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-6">
        <rdfs:label>Message</rdfs:label>
        <rdfs:comment>A unit of communication posted in a channel</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-5">
        <rdfs:label>Role</rdfs:label>
        <rdfs:comment>A permission set + identity label assigned to members</rdfs:comment>
        <ont:icon>💳</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-4">
        <rdfs:label>Member</rdfs:label>
        <rdfs:comment>A person who has joined the server</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-3">
        <rdfs:label>Category</rdfs:label>
        <rdfs:comment>A grouping of channels</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-2">
        <rdfs:label>Channel</rdfs:label>
        <rdfs:comment>A space for communication (text, voice, forum, announcement)</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/discord-server-ontology/New-entity-1">
        <rdfs:label>Guild</rdfs:label>
        <rdfs:comment>Top level entity for a Discord Server</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-11_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-11"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-11_emote">
        <rdfs:label>emote</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-11"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-10_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-10"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-9_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-9_action">
        <rdfs:label>action</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-9_reason">
        <rdfs:label>reason</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-9_timestamp">
        <rdfs:label>timestamp</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-9_duration">
        <rdfs:label>duration</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-8_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-8"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-8_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-8"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-8_starttime">
        <rdfs:label>starttime</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-8"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-7_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-7"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-7_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-7"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-6_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-5_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-5_colour">
        <rdfs:label>colour</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-5_is_mentionable">
        <rdfs:label>is_mentionable</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-5_permissions">
        <rdfs:label>permissions</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-5_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-4_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-4_join_date">
        <rdfs:label>join_date</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-4_message_count">
        <rdfs:label>message_count</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-4_last_active">
        <rdfs:label>last_active</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-3_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-3_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-2_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-2_type">
        <rdfs:label>type</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>enum</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-2_description">
        <rdfs:label>description</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-2_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-1_id">
        <rdfs:label>id</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/discord-server-ontology/new-entity-1_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-16">
        <rdfs:label>hosted in</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-8"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:comment>Many events can be hosted in a channel over time; each event instance is hosted in one channel</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-8</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-15">
        <rdfs:label>attends</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-8"/>
        <rdfs:comment>A member can attend many events; an event can have many attendees</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-8</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-14">
        <rdfs:label>targets</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:comment>A member can receive many moderation actions over time; each action targets one member</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-9</ont:fromEntityId>
        <ont:toEntityId>new-entity-4</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-13">
        <rdfs:label>assigns</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-7"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:comment>A bot can assign many roles; a role can be assigned by many bots</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-7</ont:fromEntityId>
        <ont:toEntityId>new-entity-5</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-12">
        <rdfs:label>enforces</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-7"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-9"/>
        <rdfs:comment>One bot issues many moderation actions, but each action is issued by one source (bot or member)</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-7</ont:fromEntityId>
        <ont:toEntityId>new-entity-9</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-11">
        <rdfs:label>monitors</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-7"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:comment>A bot can monitor many channels; a channel can be monitored by many bots</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-7</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-10">
        <rdfs:label>spawns</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-10"/>
        <rdfs:comment>One message can spawn one thread, each thread originates from one message</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-6</ont:fromEntityId>
        <ont:toEntityId>new-entity-10</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-9">
        <rdfs:label>receives</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-11"/>
        <rdfs:comment>One message can have many reactions, each reaction belongs to one message</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-6</ont:fromEntityId>
        <ont:toEntityId>new-entity-11</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-8">
        <rdfs:label>appears in</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-6"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:comment>Many messages live in a channel, each message belongs to one channel</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-6</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-7">
        <rdfs:label>posts</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-6"/>
        <rdfs:comment>One member authors many messages, but each message has one author</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-6</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-6">
        <rdfs:label>grants access to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:comment>A role can unlock many channels; a channel can be accessible by many roles</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-5</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-5">
        <rdfs:label>holds</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-5"/>
        <rdfs:comment>A member can hold multiple roles; a role can be held by many members</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-5</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-4">
        <rdfs:label>belongs to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-1"/>
        <rdfs:comment>A member can be in multiple servers; a server has many members</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-1</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-3">
        <rdfs:label>groups</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-3"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:comment>One category holds many channels, but a channel belongs to one category (or none)</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-3</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-2">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-2"/>
        <rdfs:comment>One server has many channels, each channel belongs to one server</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/discord-server-ontology/rel-relates-to-1">
        <rdfs:label>contains</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/discord-server-ontology/New-entity-3"/>
        <rdfs:comment>One server has many categories, each category belongs to one server</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
