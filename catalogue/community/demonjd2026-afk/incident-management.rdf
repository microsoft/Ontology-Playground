<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/incident-management/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/incident-management/">

    <owl:Ontology rdf:about="http://example.org/ontology/incident-management/">
        <rdfs:label>Incident Management</rdfs:label>
        <rdfs:comment>Models the people, systems, and artifacts in an enterprise incident management workflow.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-12">
        <rdfs:label>ChangeRequest</rdfs:label>
        <rdfs:comment>The governed deployment vehicle through which a resolution is released to a controlled environment. Provides the audit trail, approval, and scheduled window required by enterprise change-management processes.</rdfs:comment>
        <ont:icon>🏷️</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-11">
        <rdfs:label>Resolution</rdfs:label>
        <rdfs:comment>The fix or workaround applied to close the incident. May be a permanent code fix, a configuration change, a rollback to a previous version, or a temporary workaround pending a longer-term solution.</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-10">
        <rdfs:label>RootCause</rdfs:label>
        <rdfs:comment>The underlying defect or condition that produced the incident. Categorized by type (code, configuration, data, or infrastructure) to support trend analysis and prevention.</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-9">
        <rdfs:label>BusinessOwner</rdfs:label>
        <rdfs:comment>The accountable owner of the affected application or business process. Reports the real-world impact, signs off on the resolution, and is the final stakeholder informed when the incident is closed.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-8">
        <rdfs:label>Tester</rdfs:label>
        <rdfs:comment>Validates the proposed fix in lower environments before it is released. Confirms that the resolution actually solves the original incident and does not introduce regressions.</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-7">
        <rdfs:label>BusinessAnalyst</rdfs:label>
        <rdfs:comment>Translates technical incident details into business impact and vice versa. Helps the technical team understand what business processes are affected and helps the business understand what is being done about it.</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-6">
        <rdfs:label>ScrumMaster</rdfs:label>
        <rdfs:comment>The team coordinator who runs the incident response process. Removes blockers, manages communication, runs the war room or bridge call, and ensures the right people are engaged at the right time.</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-5">
        <rdfs:label>SMEArchitect</rdfs:label>
        <rdfs:comment>A subject-matter expert or architect with deep domain or technical knowledge. Consulted when an incident requires authority beyond a single developer, such as cross-system design decisions or complex root-cause analysis.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-4">
        <rdfs:label>Developer</rdfs:label>
        <rdfs:comment>The engineer assigned to investigate and fix the incident. Owns the technical debugging, code or configuration change, and works with other roles to drive the incident to resolution.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-3">
        <rdfs:label>Environment</rdfs:label>
        <rdfs:comment>The deployment context where an incident occurs, such as Production, UAT, or Development. Distinguishing the environment is essential because the same defect can have very different business impact depending on where it surfaces.</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-2">
        <rdfs:label>Application</rdfs:label>
        <rdfs:comment>A software service or system that delivers business functionality. The application is the subject of an incident — what is broken, slow, or behaving unexpectedly.</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management/New-entity-1">
        <rdfs:label>Incident</rdfs:label>
        <rdfs:comment>An unplanned disruption or degradation of a service that requires investigation and resolution. Tracked by severity, status, and SLA target from the moment it is reported until it is closed.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

