    <owl:DatatypeProperty rdf:about="http://example.org/ontology/incident-management/new-entity-1_slaTarget">
        <rdfs:label>slaTarget</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/incident-management/new-entity-1_source">
        <rdfs:label>source</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-15">
        <rdfs:label>affects</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-2"/>
        <rdfs:comment>An incident affects a specific application — the system that is broken or degraded.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-14">
        <rdfs:label>occursIn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-3"/>
        <rdfs:comment>Identifies which environment the incident surfaced in (Production, UAT, Dev).</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-13">
        <rdfs:label>assignedTo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-4"/>
        <rdfs:comment>When an incident requires deeper expertise, it escalates to a subject-matter expert or architect.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-4</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-12">
        <rdfs:label>escalatesTo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-5"/>
        <rdfs:comment>When an incident requires deeper expertise, it escalates to a subject-matter expert or architect.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-5</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-11">
        <rdfs:label>coordinatedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-6"/>
        <rdfs:comment>The scrum master who coordinates the response, runs the war room, and removes blockers.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-6</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-10">
        <rdfs:label>consults</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-7"/>
        <rdfs:comment>The developer consults the business analyst to understand business impact and clarify requirements.</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-7</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-9">
        <rdfs:label>notifies</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-7"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-9"/>
        <rdfs:comment>The business analyst notifies the affected business owner about incident impact and progress.</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-7</ont:fromEntityId>
        <ont:toEntityId>new-entity-9</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-8">
        <rdfs:label>identifies</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-4"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-10"/>
        <rdfs:comment>The developer identifies the underlying defect or condition that caused the incident.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-4</ont:fromEntityId>
        <ont:toEntityId>new-entity-10</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-7">
        <rdfs:label>leadsTo</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-10"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-11"/>
        <rdfs:comment>The root cause leads to a resolution - the fix or workaround that closes the incident.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-10</ont:fromEntityId>
        <ont:toEntityId>new-entity-11</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-6">
        <rdfs:label>validatedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-11"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-8"/>
        <rdfs:comment>The resolution is deployed to production through a governed change request, providing the audit trail.</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-11</ont:fromEntityId>
        <ont:toEntityId>new-entity-8</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management/rel-relates-to-5">
        <rdfs:label>deployedVia</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management/New-entity-11"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management/New-entity-12"/>
        <rdfs:comment>The resolution is deployed to production through a governed change request, providing the audit trail.</rdfs:comment>
        <ont:cardinality>one-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-11</ont:fromEntityId>
        <ont:toEntityId>new-entity-12</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
