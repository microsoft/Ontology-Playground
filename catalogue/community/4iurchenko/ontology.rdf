<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/">

    <owl:Ontology rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/">
        <rdfs:label>Vitala — Wellbeing Check Ontology v0.6</rdfs:label>
        <rdfs:comment>D2C wellbeing-check ontology for U.S. working-age adults. v0.6: Purchase becomes the anchor for channel, payment, and product attribution. 15 entities, 17 relations. Entity numbering and ont:x / ont:y reflect the spatial layout from &quot;Ontology 0.5 - Final - Corrections.png&quot; (top-to-bottom, left-to-right).</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-1">
        <rdfs:label>ActionCompletion</rdfs:label>
        <rdfs:comment>A Member&apos;s completion of a recommended Action. Source indicates whether it was self-reported, system-detected, or verified.</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-2">
        <rdfs:label>EngagementMessage</rdfs:label>
        <rdfs:comment>A nudge, reminder, or coaching message sent to a Member, seeded by a WellbeingReport.</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-3">
        <rdfs:label>EmployerChannelPartner</rdfs:label>
        <rdfs:comment>Employer or affiliate through which a Purchase was acquired (sponsored fair, co-branded deal, etc.).</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-4">
        <rdfs:label>Action</rdfs:label>
        <rdfs:comment>A recommendation generated by a WellbeingReport (lifestyle change, follow-up booking, PCP referral, habit). Optionally targets a specific RiskFlag.</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-5">
        <rdfs:label>WellbeingReport</rdfs:label>
        <rdfs:comment>The Member-facing deliverable produced from a Purchase. Carries a composite score and delta vs. prior report.</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-6">
        <rdfs:label>Purchase</rdfs:label>
        <rdfs:comment>One Purchase = one wellbeing check delivery. Either a standalone package or a membership delivery. In v0.6 also anchors paidWith→PaymentMethod, attributedTo→EmployerChannelPartner, and forProduct→Product.</rdfs:comment>
        <ont:icon>🛒</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-7">
        <rdfs:label>Member</rdfs:label>
        <rdfs:comment>The end consumer of the wellbeing check service. The Member is the subject of care whose wellbeing data is collected, scored, and tracked over time.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-8">
        <rdfs:label>PaymentMethod</rdfs:label>
        <rdfs:comment>One row per card or bank account on file. Anchored to Purchase via paidWith.</rdfs:comment>
        <ont:icon>🔗</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-9">
        <rdfs:label>RiskFlag</rdfs:label>
        <rdfs:comment>A clinical-risk indicator inferred from Observations (e.g., pre-diabetes, hypertension, depression risk). Has a lifecycle (opened → resolved).</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-10">
        <rdfs:label>BillingEvent</rdfs:label>
        <rdfs:comment>A billing attempt: charge, refund, or chargeback. reversesBillingEventId is set when kind = refund or chargeback (points to the original charge).</rdfs:comment>
        <ont:icon>💳</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-11">
        <rdfs:label>Membership</rdfs:label>
        <rdfs:comment>A Member&apos;s enrollment in a recurring product. Transactional: each renewal creates a new row. Only the active row has isCurrent = true. Renewal count = row count per Member.</rdfs:comment>
        <ont:icon>🏷️</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-12">
        <rdfs:label>Product</rdfs:label>
        <rdfs:comment>Catalog SKU. The thing a Member buys (membership, package, or addon). Defines pricing and cadence.</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-13">
        <rdfs:label>Observation</rdfs:label>
        <rdfs:comment>A single data point produced by an Encounter — biomarker value, biometric reading, or questionnaire response. Coded with LOINC or SNOMED.</rdfs:comment>
        <ont:icon>📊</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-14">
        <rdfs:label>Encounter</rdfs:label>
        <rdfs:comment>A single touchpoint that produces data: Intake, Biometric measurement, or BloodDraw.</rdfs:comment>
        <ont:icon>🎯</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/vitala-wellbeing-check-ontology-v06/New-entity-15">
        <rdfs:label>LabPartner</rdfs:label>
        <rdfs:comment>External laboratory that performs blood draws and biomarker analysis.</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

