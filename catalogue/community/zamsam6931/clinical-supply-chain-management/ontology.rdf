<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/clinical-supply-chain-management/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/clinical-supply-chain-management/">

    <owl:Ontology rdf:about="http://example.org/ontology/clinical-supply-chain-management/">
        <rdfs:label>Clinical Supply Chain Management</rdfs:label>
        <rdfs:comment>            Enterprise Clinical Supply Chain Knowledge Graph  for Microsoft Fabric Ontology Playground        </rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Study">
        <rdfs:label>Study</rdfs:label>
        <rdfs:comment>Represents a clinical trial or research study.</rdfs:comment>
        <ont:icon>📝</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Site">
        <rdfs:label>Site</rdfs:label>
        <rdfs:comment>Represents a clinical research center or hospital.</rdfs:comment>
        <ont:icon>🏢</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Patient">
        <rdfs:label>Patient</rdfs:label>
        <rdfs:comment>Represents a participant enrolled in a study.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Enrollment">
        <rdfs:label>Enrollment</rdfs:label>
        <rdfs:comment>Tracks patient recruitment and enrollment metrics.</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Visit">
        <rdfs:label>Visit</rdfs:label>
        <rdfs:comment>Represents a patient interaction or treatment visit.</rdfs:comment>
        <ont:icon>🔗</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Compound">
        <rdfs:label>Compound</rdfs:label>
        <rdfs:comment>Represents investigational drug products.</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Manufacturing">
        <rdfs:label>Manufacturing</rdfs:label>
        <rdfs:comment>Represents manufacturing operations and production batches.</rdfs:comment>
        <ont:icon>🔧</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Demand">
        <rdfs:label>Demand</rdfs:label>
        <rdfs:comment>Represents forecasted clinical supply demand.</rdfs:comment>
        <ont:icon>📈</ont:icon>
        <ont:color>#E81123</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Depot">
        <rdfs:label>Depot</rdfs:label>
        <rdfs:comment>Regional supply storage center</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Shipment">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>Represents movement of inventory between locations.</rdfs:comment>
        <ont:icon>🛒</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Inventory">
        <rdfs:label>Inventory</rdfs:label>
        <rdfs:comment>Represents available stock of clinical supplies.</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#008272</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Country">
        <rdfs:label>Country</rdfs:label>
        <rdfs:comment>Country geographic entity</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/clinical-supply-chain-management/Region">
        <rdfs:label>Region</rdfs:label>
        <rdfs:comment>Geographic region</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/study_studyId">
        <rdfs:label>studyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Study"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/study_studyName">
