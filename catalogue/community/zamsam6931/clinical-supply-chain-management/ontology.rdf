    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/rel-relates-to-2">
        <rdfs:label>has demand</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Demand"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>patient</ont:fromEntityId>
        <ont:toEntityId>demand</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/hasSite">
        <rdfs:label>has site</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Study"/>
        <rdfs:range rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Site"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>study</ont:fromEntityId>
        <ont:toEntityId>site</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/usesCompound">
