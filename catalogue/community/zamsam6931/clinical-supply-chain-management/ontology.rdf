        <rdfs:label>shipment_quantity</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

