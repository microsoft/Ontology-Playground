    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/hasEnrollment">
        <rdfs:label>has enrollment</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Study"/>
        <rdfs:range rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Enrollment"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>study</ont:fromEntityId>
        <ont:toEntityId>enrollment</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/enrolledAt">
        <rdfs:label>enrolled at</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Site"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>patient</ont:fromEntityId>
        <ont:toEntityId>site</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/participatesIn">
        <rdfs:label>participates in</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Study"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>patient</ont:fromEntityId>
        <ont:toEntityId>study</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/hasVisit">
        <rdfs:label>has visit</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Patient"/>
        <rdfs:range rdf:resource="http://example.org/ontology/clinical-supply-chain-management/Visit"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>patient</ont:fromEntityId>
        <ont:toEntityId>visit</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/clinical-supply-chain-management/occursAt">
        <rdfs:label>occurs at</rdfs:label>
