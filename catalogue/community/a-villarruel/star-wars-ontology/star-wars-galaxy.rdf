<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/star-wars-galaxy/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/star-wars-galaxy/">

    <owl:Ontology rdf:about="http://example.org/ontology/star-wars-galaxy/">
        <rdfs:label>Star Wars Galaxy</rdfs:label>
        <rdfs:comment>The balance of the Force and galactic conflict</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/New-entity-5">
        <rdfs:label>Species</rdfs:label>
        <rdfs:comment>Human, Wookiee, Twi’lek, Zabrak…</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/New-entity-4">
        <rdfs:label>Starship</rdfs:label>
        <rdfs:comment>Millennium Falcon, X-Wing, Star Destroyer…</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/New-entity-3">
        <rdfs:label>Event</rdfs:label>
        <rdfs:comment>Order 66, Battle of Yavin, Duel on Mustafar…</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/New-entity-2">
        <rdfs:label>Artifact</rdfs:label>
        <rdfs:comment>Lightsaber, Holocron, Death Star, Kyber Crystal…</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/New-entity-1">
        <rdfs:label>Planet</rdfs:label>
        <rdfs:comment>Planet or StarSystem (Tatooine, Coruscant, Dagobah, Mustafar, Endor…).</rdfs:comment>
        <ont:icon>🌐</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/Device">
        <rdfs:label>forceSensitiveBeing</rdfs:label>
        <rdfs:comment>This is the base entity for anyone who can use the Force (Jedi, Sith, Padawan, Master, Inquisitor, etc.).</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/Sensor">
        <rdfs:label>Character</rdfs:label>
        <rdfs:comment>A sentient being who exists and acts within the Star Wars galaxy, serving as the primary agent of stories, conflicts, and destiny. Examples: Luke Skywalker (Jedi hero), Darth Vader (fallen Sith), Han Solo (smuggler turned rebel), Yoda (ancient Jedi Master), Princess Leia (senator and leader).</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/star-wars-galaxy/Reading">
        <rdfs:label>Faction</rdfs:label>
        <rdfs:comment>Galactic Republic, Galactic Empire, Rebel Alliance, Jedi Order, Sith Order, Bounty Hunter Guild, etc.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

