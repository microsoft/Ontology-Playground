    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-8">
        <rdfs:label>isWieldedBy</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-2"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/Sensor"/>
        <rdfs:comment>An artifact is primarily wielded by one character.</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-2</ont:fromEntityId>
        <ont:toEntityId>sensor</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-7">
        <rdfs:label>controlsA</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/Reading"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-1"/>
        <rdfs:comment>A Faction controls a Planet or System.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>reading</ont:fromEntityId>
        <ont:toEntityId>new-entity-1</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-6">
        <rdfs:label>isHomeworldOf</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/Sensor"/>
        <rdfs:comment>A planet is the birthplace/homeworld of characters.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>sensor</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-5">
        <rdfs:label>participatesIn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/Sensor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-3"/>
        <rdfs:comment>A character participates in a historical event.</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>sensor</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-4">
        <rdfs:label>isHomeworldOf</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-1"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-5"/>
        <rdfs:comment>A planet is the homeworld of one or more species.</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>new-entity-1</ont:fromEntityId>
        <ont:toEntityId>new-entity-5</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-3">
        <rdfs:label>pilots</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/Sensor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-4"/>
        <rdfs:comment>A character pilots one or more starships (Han Solo pilots the Millennium Falcon).</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>sensor</ont:fromEntityId>
        <ont:toEntityId>new-entity-4</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-2">
        <rdfs:label>uses</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/Sensor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-2"/>
        <rdfs:comment>A character uses one or more artifacts (Luke uses a Lightsaber</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>sensor</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/rel-relates-to-1">
        <rdfs:label>occursOn</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-3"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/New-entity-1"/>
        <rdfs:comment>An event takes place on a specific planet (Battle of Yavin occursOn Yavin 4).</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>new-entity-3</ont:fromEntityId>
        <ont:toEntityId>new-entity-1</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/r-has-sensor">
        <rdfs:label>isMemberOf</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/Sensor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/Reading"/>
        <rdfs:comment>A character belongs to one primary faction or organization at a given time (e.g., Luke isMemberOf Rebel Alliance)</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>sensor</ont:fromEntityId>
        <ont:toEntityId>reading</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/star-wars-galaxy/r-produces">
        <rdfs:label>isMemberOf</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/star-wars-galaxy/Device"/>
        <rdfs:range rdf:resource="http://example.org/ontology/star-wars-galaxy/Reading"/>
        <rdfs:comment>A Force user belongs to an Order or faction (Jedi Order, Sith Order, etc.).</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>device</ont:fromEntityId>
        <ont:toEntityId>reading</ont:toEntityId>
    </owl:ObjectProperty>

