    <!-- ================== -->
    <!-- Object Properties -->
    <!-- ================== -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management-ontology/rel-relates-to-11">
        <rdfs:label>is supported by</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/Sensor"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management-ontology/New-entity-3"/>
        <rdfs:comment>Service is supported by Configuration Item</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>sensor</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management-ontology/rel-relates-to-10">
        <rdfs:label>relates to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/Device"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management-ontology/New-entity-4"/>
        <rdfs:comment>Incident is related to Problem</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>device</ont:fromEntityId>
        <ont:toEntityId>new-entity-4</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management-ontology/rel-relates-to-8">
        <rdfs:label>is assigned to</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/Device"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management-ontology/New-entity-2"/>
        <rdfs:comment>Incident is assigned to Assignee</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>device</ont:fromEntityId>
        <ont:toEntityId>new-entity-2</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management-ontology/rel-relates-to-7">
        <rdfs:label>impacts</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/Device"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management-ontology/New-entity-3"/>
        <rdfs:comment>Incident impacts Configuration Item</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>device</ont:fromEntityId>
        <ont:toEntityId>new-entity-3</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management-ontology/rel-relates-to-6">
        <rdfs:label>affects </rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/Device"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management-ontology/Sensor"/>
        <rdfs:comment>Incident affects Service</rdfs:comment>
        <ont:cardinality>many-to-many</ont:cardinality>
        <ont:fromEntityId>device</ont:fromEntityId>
        <ont:toEntityId>sensor</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/incident-management-ontology/rel-relates-to-4">
        <rdfs:label>reports</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/Reading"/>
        <rdfs:range rdf:resource="http://example.org/ontology/incident-management-ontology/Device"/>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>reading</ont:fromEntityId>
        <ont:toEntityId>device</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
