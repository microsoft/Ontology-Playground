<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/incident-management-ontology/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/incident-management-ontology/">

    <owl:Ontology rdf:about="http://example.org/ontology/incident-management-ontology/">
        <rdfs:label>Incident Management Ontology</rdfs:label>
        <rdfs:comment>Incident Management domain. It aligns with ITIL 4 best practices.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/incident-management-ontology/New-entity-4">
        <rdfs:label>Problem</rdfs:label>
        <rdfs:comment>Known error or root cause for linking recurring incidents</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management-ontology/New-entity-3">
        <rdfs:label>ConfigurationItem</rdfs:label>
        <rdfs:comment>Underlying asset or component causing or affected by the incident – ITIL CMDB concept</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#00A9E0</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management-ontology/New-entity-2">
        <rdfs:label>Assignee</rdfs:label>
        <rdfs:comment>Support Analyst, Team, or Group responsible for resolution</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management-ontology/Device">
        <rdfs:label>Incident</rdfs:label>
        <rdfs:comment>Central concept. Unplanned interruption or reduction in service quality</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#34495E</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management-ontology/Sensor">
        <rdfs:label>Service</rdfs:label>
        <rdfs:comment>Business or IT Service being disrupted</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#E74C3C</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/incident-management-ontology/Reading">
        <rdfs:label>User</rdfs:label>
        <rdfs:comment>Employee / Reporter. The person raising the incident</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#3498DB</ont:color>
    </owl:Class>

    <!-- ================ -->
    <!-- Data Properties -->
    <!-- ================ -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/incident-management-ontology/new-entity-4_problemId">
        <rdfs:label>problemId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/incident-management-ontology/New-entity-4"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/incident-management-ontology/new-entity-4_title">
