<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/cruise-company-operations/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/cruise-company-operations/">

    <owl:Ontology rdf:about="http://example.org/ontology/cruise-company-operations/">
        <rdfs:label>Cruise Company Operations</rdfs:label>
        <rdfs:comment>Cruise line operations &amp; guest experience.</rdfs:comment>
    </owl:Ontology>

    <!-- ===================== -->
    <!-- Entity Types (Classes) -->
    <!-- ===================== -->

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-9">
        <rdfs:label>LoyaltyTier</rdfs:label>
        <rdfs:comment>Loyalty program levels (Silver, Gold, Platinum, Diamond).</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-8">
        <rdfs:label>Department</rdfs:label>
        <rdfs:comment>Organizational unit (Hotel, Deck, Engine, Food &amp; Beverage, Entertainment, etc.).</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-7">
        <rdfs:label>CrewMember</rdfs:label>
        <rdfs:comment>Employee working on the ship.</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-6">
        <rdfs:label>OnboardService</rdfs:label>
        <rdfs:comment>Any paid or complimentary service consumed onboard.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-5">
        <rdfs:label>Excursion</rdfs:label>
        <rdfs:comment>Shore excursion or tour.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-4">
        <rdfs:label>Port</rdfs:label>
        <rdfs:comment>Destination port / city.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-3">
        <rdfs:label>Itinerary</rdfs:label>
        <rdfs:comment>Route and sequence of ports.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-2">
        <rdfs:label>Cabin</rdfs:label>
        <rdfs:comment>Individual stateroom or suite.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/New-entity-1">
        <rdfs:label>Ship</rdfs:label>
        <rdfs:comment>Physical vessel (e.g. Fabric Dream, Fabric Adventure)</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/Customer">
        <rdfs:label>Guest</rdfs:label>
        <rdfs:comment>Individual passenger (includes loyalty members).</rdfs:comment>
        <ont:icon>👤</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/Product">
        <rdfs:label>Booking</rdfs:label>
        <rdfs:comment>Reservation / booking record.</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/cruise-company-operations/Order">
        <rdfs:label>Sailing</rdfs:label>
        <rdfs:comment>Specific departure of a ship (e.g. 7-night Mediterranean on July 15).</rdfs:comment>
        <ont:icon>⚡</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

