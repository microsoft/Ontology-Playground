<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/zava-grove-to-shelf-step-5/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/zava-grove-to-shelf-step-5/">

    <owl:Ontology rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/">
        <rdfs:label>Zava Grove-to-Shelf</rdfs:label>
        <rdfs:comment>Zava's complete grove-to-shelf ontology — multi-origin sourcing, four-stage QC, cold-chain logistics, retail orders, and sustainability — in 12 entities and 13 relationships.</rdfs:comment>
    </owl:Ontology>

    <!-- Entity Types -->
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Grower">
        <rdfs:label>Grower</rdfs:label>
        <rdfs:comment>A partner producer of fresh fruit and vegetables</rdfs:comment>
        <ont:icon>👨‍🌾</ont:icon>
        <ont:color>#498205</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Farm">
        <rdfs:label>Farm</rdfs:label>
        <rdfs:comment>A geographic site owned or contracted by a grower</rdfs:comment>
        <ont:icon>🌾</ont:icon>
        <ont:color>#6EAA1F</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Plot">
        <rdfs:label>Plot</rdfs:label>
        <rdfs:comment>A managed parcel within a farm planted with one variety</rdfs:comment>
        <ont:icon>🌱</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety">
        <rdfs:label>FruitVariety</rdfs:label>
        <rdfs:comment>A commercial fruit or vegetable variety</rdfs:comment>
        <ont:icon>🍊</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Harvestlot">
        <rdfs:label>HarvestLot</rdfs:label>
        <rdfs:comment>A traceable harvest event from a single plot</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Qualitycheck">
        <rdfs:label>QualityCheck</rdfs:label>
        <rdfs:comment>One of the four-stage quality inspections</rdfs:comment>
        <ont:icon>🔍</ont:icon>
        <ont:color>#C239B3</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Shipment">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>A reefer container or truck moving lots to a retail DC</rdfs:comment>
        <ont:icon>🚛</ont:icon>
        <ont:color>#0099BC</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Coldchainsensor">
        <rdfs:label>ColdChainSensor</rdfs:label>
        <rdfs:comment>Live temperature and humidity sensor on a shipment</rdfs:comment>
        <ont:icon>🌡️</ont:icon>
        <ont:color>#005A9E</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Retaildc">
        <rdfs:label>RetailDC</rdfs:label>
        <rdfs:comment>A retailer's distribution centre receiving shipments</rdfs:comment>
        <ont:icon>🏬</ont:icon>
        <ont:color>#2D7D9A</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Store">
        <rdfs:label>Store</rdfs:label>
        <rdfs:comment>A retailer storefront supplied by a DC</rdfs:comment>
        <ont:icon>🏪</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Order">
        <rdfs:label>Order</rdfs:label>
        <rdfs:comment>A purchase order placed by a store for a fruit variety</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/Sustainabilityprogram">
        <rdfs:label>SustainabilityProgram</rdfs:label>
        <rdfs:comment>A grower-development or CSR program farms can join (e.g. Zava Dreams)</rdfs:comment>
        <ont:icon>🌍</ont:icon>
        <ont:color>#486860</ont:color>
    </owl:Class>

    <!-- Data Properties (full set for the demo) -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/grower_growerId">
        <rdfs:label>growerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/grower_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/grower_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/grower_partnerSince">
        <rdfs:label>partnerSince</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/grower_isMasterGrower">
        <rdfs:label>isMasterGrower</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/farm_farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/farm_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/farm_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/farm_region">
        <rdfs:label>region</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/farm_hectares">
        <rdfs:label>hectares</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>ha</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/plot_plotId">
        <rdfs:label>plotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/plot_hectares">
        <rdfs:label>hectares</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>ha</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/plot_plantingYear">
        <rdfs:label>plantingYear</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/fruitvariety_varietyId">
        <rdfs:label>varietyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/fruitvariety_commercialName">
        <rdfs:label>commercialName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/fruitvariety_category">
        <rdfs:label>category</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/fruitvariety_minStorageTempC">
        <rdfs:label>minStorageTempC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/fruitvariety_maxStorageTempC">
        <rdfs:label>maxStorageTempC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/fruitvariety_shelfLifeDays">
        <rdfs:label>shelfLifeDays</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/harvestlot_lotId">
        <rdfs:label>lotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/harvestlot_harvestDate">
        <rdfs:label>harvestDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/harvestlot_kilograms">
        <rdfs:label>kilograms</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>kg</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/harvestlot_qcGrade">
        <rdfs:label>qcGrade</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/qualitycheck_checkId">
        <rdfs:label>checkId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/qualitycheck_stage">
        <rdfs:label>stage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/qualitycheck_passed">
        <rdfs:label>passed</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/qualitycheck_defectRate">
        <rdfs:label>defectRate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/shipment_shipmentId">
        <rdfs:label>shipmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/shipment_modality">
        <rdfs:label>modality</rdfs:label>
