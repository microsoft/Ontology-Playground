    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/shipment_etaDate">
        <rdfs:label>etaDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/coldchainsensor_sensorId">
        <rdfs:label>sensorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/coldchainsensor_temperatureC">
        <rdfs:label>temperatureC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/coldchainsensor_humidityPct">
        <rdfs:label>humidityPct</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/retaildc_dcId">
        <rdfs:label>dcId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Retaildc"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/retaildc_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Retaildc"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/retaildc_retailerCode">
        <rdfs:label>retailerCode</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-5/Retaildc"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-5/store_storeId">
