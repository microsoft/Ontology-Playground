<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/zava-grove-to-shelf-step-3/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/zava-grove-to-shelf-step-3/">

    <owl:Ontology rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/">
        <rdfs:label>Zava Grove-to-Shelf — Step 3: Cold-Chain Logistics</rdfs:label>
        <rdfs:comment>Add Shipment and ColdChainSensor for perishable logistics and live temperature telemetry.</rdfs:comment>
    </owl:Ontology>

    <!-- Entity Types -->
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Grower">
        <rdfs:label>Grower</rdfs:label>
        <rdfs:comment>A partner producer of fresh fruit and vegetables</rdfs:comment>
        <ont:icon>👨‍🌾</ont:icon>
        <ont:color>#498205</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Farm">
        <rdfs:label>Farm</rdfs:label>
        <rdfs:comment>A geographic site owned or contracted by a grower</rdfs:comment>
        <ont:icon>🌾</ont:icon>
        <ont:color>#6EAA1F</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Plot">
        <rdfs:label>Plot</rdfs:label>
        <rdfs:comment>A managed parcel within a farm planted with one variety</rdfs:comment>
        <ont:icon>🌱</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Fruitvariety">
        <rdfs:label>FruitVariety</rdfs:label>
        <rdfs:comment>A commercial fruit or vegetable variety</rdfs:comment>
        <ont:icon>🍊</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Harvestlot">
        <rdfs:label>HarvestLot</rdfs:label>
        <rdfs:comment>A traceable harvest event from a single plot on a given date</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Qualitycheck">
        <rdfs:label>QualityCheck</rdfs:label>
        <rdfs:comment>One of the four-stage quality inspections</rdfs:comment>
        <ont:icon>🔍</ont:icon>
        <ont:color>#C239B3</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Shipment">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>A reefer container or truck moving harvest lots to a retail DC</rdfs:comment>
        <ont:icon>🚛</ont:icon>
        <ont:color>#0099BC</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/Coldchainsensor">
        <rdfs:label>ColdChainSensor</rdfs:label>
        <rdfs:comment>A temperature and humidity sensor attached to a shipment, streaming telemetry</rdfs:comment>
        <ont:icon>🌡️</ont:icon>
        <ont:color>#005A9E</ont:color>
    </owl:Class>

    <!-- Data Properties (carried forward + new) -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/grower_growerId">
        <rdfs:label>growerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/grower_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/grower_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/farm_farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/farm_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/farm_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/farm_region">
        <rdfs:label>region</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/plot_plotId">
        <rdfs:label>plotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/plot_hectares">
        <rdfs:label>hectares</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>ha</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/fruitvariety_varietyId">
        <rdfs:label>varietyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/fruitvariety_commercialName">
        <rdfs:label>commercialName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/fruitvariety_category">
        <rdfs:label>category</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/fruitvariety_minStorageTempC">
        <rdfs:label>minStorageTempC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/fruitvariety_maxStorageTempC">
        <rdfs:label>maxStorageTempC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/harvestlot_lotId">
        <rdfs:label>lotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/harvestlot_harvestDate">
        <rdfs:label>harvestDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/harvestlot_kilograms">
        <rdfs:label>kilograms</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>kg</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/harvestlot_qcGrade">
        <rdfs:label>qcGrade</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/qualitycheck_checkId">
        <rdfs:label>checkId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/qualitycheck_stage">
        <rdfs:label>stage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/qualitycheck_passed">
        <rdfs:label>passed</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Shipment properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment_shipmentId">
        <rdfs:label>shipmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment_departureDate">
        <rdfs:label>departureDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment_etaDate">
        <rdfs:label>etaDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment_modality">
        <rdfs:label>modality</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment_containerId">
        <rdfs:label>containerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- ColdChainSensor properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/coldchainsensor_sensorId">
        <rdfs:label>sensorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/coldchainsensor_sensorModel">
        <rdfs:label>sensorModel</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/coldchainsensor_temperatureC">
        <rdfs:label>temperatureC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/coldchainsensor_humidityPct">
        <rdfs:label>humidityPct</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-3/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/grower-owns-farm">
        <rdfs:label>GrowerOwnsFarm</rdfs:label>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>grower</ont:fromEntityId>
        <ont:toEntityId>farm</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/farm-contains-plot">
        <rdfs:label>FarmContainsPlot</rdfs:label>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>farm</ont:fromEntityId>
        <ont:toEntityId>plot</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/plot-grows-fruitvariety">
        <rdfs:label>PlotGrowsFruitVariety</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>plot</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/harvestlot-fromplot-plot">
        <rdfs:label>HarvestLotFromPlot</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>harvestlot</ont:fromEntityId>
        <ont:toEntityId>plot</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/harvestlot-ofvariety-fruitvariety">
        <rdfs:label>HarvestLotOfVariety</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>harvestlot</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/qualitycheck-checks-harvestlot">
        <rdfs:label>QualityCheckChecksHarvestLot</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>qualitycheck</ont:fromEntityId>
        <ont:toEntityId>harvestlot</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment-carries-harvestlot">
        <rdfs:label>ShipmentCarriesHarvestLot</rdfs:label>
        <rdfs:comment>A shipment carries one or more harvest lots</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>harvestlot</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-3/shipment-monitoredby-coldchainsensor">
        <rdfs:label>ShipmentMonitoredBySensor</rdfs:label>
        <rdfs:comment>A shipment is monitored by one or more cold-chain sensors</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>coldchainsensor</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
