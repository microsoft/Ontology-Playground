<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/zava-grove-to-shelf-step-2/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/zava-grove-to-shelf-step-2/">

    <owl:Ontology rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/">
        <rdfs:label>Zava Grove-to-Shelf — Step 2: Harvest &amp; Quality</rdfs:label>
        <rdfs:comment>Add HarvestLot and QualityCheck to capture harvest events and the four-stage QC regime.</rdfs:comment>
    </owl:Ontology>

    <!-- Entity Types (Classes) -->

    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/Grower">
        <rdfs:label>Grower</rdfs:label>
        <rdfs:comment>A partner producer of fresh fruit and vegetables</rdfs:comment>
        <ont:icon>👨‍🌾</ont:icon>
        <ont:color>#498205</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/Farm">
        <rdfs:label>Farm</rdfs:label>
        <rdfs:comment>A geographic site owned or contracted by a grower</rdfs:comment>
        <ont:icon>🌾</ont:icon>
        <ont:color>#6EAA1F</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/Plot">
        <rdfs:label>Plot</rdfs:label>
        <rdfs:comment>A managed parcel within a farm planted with one variety</rdfs:comment>
        <ont:icon>🌱</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/Fruitvariety">
        <rdfs:label>FruitVariety</rdfs:label>
        <rdfs:comment>A commercial fruit or vegetable variety</rdfs:comment>
        <ont:icon>🍊</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/Harvestlot">
        <rdfs:label>HarvestLot</rdfs:label>
        <rdfs:comment>A traceable harvest event from a single plot on a given date</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>

    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/Qualitycheck">
        <rdfs:label>QualityCheck</rdfs:label>
        <rdfs:comment>One of the four-stage quality inspections (field, packhouse, DC, store)</rdfs:comment>
        <ont:icon>🔍</ont:icon>
        <ont:color>#C239B3</ont:color>
    </owl:Class>

    <!-- Grower properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/grower_growerId">
        <rdfs:label>growerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/grower_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/grower_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/grower_isMasterGrower">
        <rdfs:label>isMasterGrower</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Farm properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/farm_farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/farm_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/farm_country">
        <rdfs:label>country</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/farm_region">
        <rdfs:label>region</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/farm_hectares">
        <rdfs:label>hectares</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>ha</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Plot properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/plot_plotId">
        <rdfs:label>plotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/plot_hectares">
        <rdfs:label>hectares</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>ha</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/plot_plantingYear">
        <rdfs:label>plantingYear</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- FruitVariety properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/fruitvariety_varietyId">
        <rdfs:label>varietyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/fruitvariety_commercialName">
        <rdfs:label>commercialName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/fruitvariety_category">
        <rdfs:label>category</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/fruitvariety_shelfLifeDays">
        <rdfs:label>shelfLifeDays</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:unit>days</ont:unit>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- HarvestLot properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/harvestlot_lotId">
        <rdfs:label>lotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/harvestlot_harvestDate">
        <rdfs:label>harvestDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
        <ont:propertyType>date</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/harvestlot_kilograms">
        <rdfs:label>kilograms</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>kg</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/harvestlot_qcGrade">
        <rdfs:label>qcGrade</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- QualityCheck properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/qualitycheck_checkId">
        <rdfs:label>checkId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/qualitycheck_stage">
        <rdfs:label>stage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/qualitycheck_passed">
        <rdfs:label>passed</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
        <ont:propertyType>boolean</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/qualitycheck_defectRate">
        <rdfs:label>defectRate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>%</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/qualitycheck_checkedAt">
        <rdfs:label>checkedAt</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-2/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#dateTime"/>
        <ont:propertyType>datetime</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- Object Properties -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/grower-owns-farm">
        <rdfs:label>GrowerOwnsFarm</rdfs:label>
        <rdfs:comment>A grower owns or operates one or more farms</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>grower</ont:fromEntityId>
        <ont:toEntityId>farm</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/farm-contains-plot">
        <rdfs:label>FarmContainsPlot</rdfs:label>
        <rdfs:comment>A farm contains many plots</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>farm</ont:fromEntityId>
        <ont:toEntityId>plot</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/plot-grows-fruitvariety">
        <rdfs:label>PlotGrowsFruitVariety</rdfs:label>
        <rdfs:comment>Each plot grows a single fruit variety per cycle</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>plot</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/harvestlot-fromplot-plot">
        <rdfs:label>HarvestLotFromPlot</rdfs:label>
        <rdfs:comment>Each harvest lot originates from one plot</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>harvestlot</ont:fromEntityId>
        <ont:toEntityId>plot</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/harvestlot-ofvariety-fruitvariety">
        <rdfs:label>HarvestLotOfVariety</rdfs:label>
        <rdfs:comment>Each harvest lot carries one fruit variety</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>harvestlot</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-2/qualitycheck-checks-harvestlot">
        <rdfs:label>QualityCheckChecksHarvestLot</rdfs:label>
        <rdfs:comment>Each quality check targets one harvest lot at a given stage</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>qualitycheck</ont:fromEntityId>
        <ont:toEntityId>harvestlot</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
