<?xml version="1.0" encoding="UTF-8"?>
<rdf:RDF
    xml:base="http://example.org/ontology/zava-grove-to-shelf-step-4/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/zava-grove-to-shelf-step-4/">

    <owl:Ontology rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/">
        <rdfs:label>Zava Grove-to-Shelf — Step 4: Retail Fulfillment</rdfs:label>
        <rdfs:comment>Add RetailDC, Store, and Order to connect the supply chain to retail partners and revenue.</rdfs:comment>
    </owl:Ontology>

    <!-- Entity Types -->
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Grower">
        <rdfs:label>Grower</rdfs:label>
        <rdfs:comment>A partner producer</rdfs:comment>
        <ont:icon>👨‍🌾</ont:icon>
        <ont:color>#498205</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Farm">
        <rdfs:label>Farm</rdfs:label>
        <rdfs:comment>A geographic site owned or contracted by a grower</rdfs:comment>
        <ont:icon>🌾</ont:icon>
        <ont:color>#6EAA1F</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Plot">
        <rdfs:label>Plot</rdfs:label>
        <rdfs:comment>A managed parcel within a farm</rdfs:comment>
        <ont:icon>🌱</ont:icon>
        <ont:color>#107C10</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Fruitvariety">
        <rdfs:label>FruitVariety</rdfs:label>
        <rdfs:comment>A commercial fruit or vegetable variety</rdfs:comment>
        <ont:icon>🍊</ont:icon>
        <ont:color>#FFB900</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Harvestlot">
        <rdfs:label>HarvestLot</rdfs:label>
        <rdfs:comment>A traceable harvest event</rdfs:comment>
        <ont:icon>📦</ont:icon>
        <ont:color>#D83B01</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Qualitycheck">
        <rdfs:label>QualityCheck</rdfs:label>
        <rdfs:comment>One of the four-stage quality inspections</rdfs:comment>
        <ont:icon>🔍</ont:icon>
        <ont:color>#C239B3</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Shipment">
        <rdfs:label>Shipment</rdfs:label>
        <rdfs:comment>A reefer container or truck</rdfs:comment>
        <ont:icon>🚛</ont:icon>
        <ont:color>#0099BC</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Coldchainsensor">
        <rdfs:label>ColdChainSensor</rdfs:label>
        <rdfs:comment>Temperature and humidity sensor on a shipment</rdfs:comment>
        <ont:icon>🌡️</ont:icon>
        <ont:color>#005A9E</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Retaildc">
        <rdfs:label>RetailDC</rdfs:label>
        <rdfs:comment>A retailer's distribution centre receiving shipments</rdfs:comment>
        <ont:icon>🏬</ont:icon>
        <ont:color>#2D7D9A</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Store">
        <rdfs:label>Store</rdfs:label>
        <rdfs:comment>A retailer storefront supplied by a DC</rdfs:comment>
        <ont:icon>🏪</ont:icon>
        <ont:color>#5C2D91</ont:color>
    </owl:Class>
    <owl:Class rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/Order">
        <rdfs:label>Order</rdfs:label>
        <rdfs:comment>A purchase order placed by a store for a fruit variety</rdfs:comment>
        <ont:icon>📋</ont:icon>
        <ont:color>#0078D4</ont:color>
    </owl:Class>

    <!-- Carry-forward properties (minimal set for graph context) -->

    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/grower_growerId">
        <rdfs:label>growerId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/grower_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Grower"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/farm_farmId">
        <rdfs:label>farmId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/farm_name">
        <rdfs:label>name</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Farm"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/plot_plotId">
        <rdfs:label>plotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Plot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/fruitvariety_varietyId">
        <rdfs:label>varietyId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/fruitvariety_commercialName">
        <rdfs:label>commercialName</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/fruitvariety_maxStorageTempC">
        <rdfs:label>maxStorageTempC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Fruitvariety"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/harvestlot_lotId">
        <rdfs:label>lotId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/harvestlot_kilograms">
        <rdfs:label>kilograms</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>kg</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/harvestlot_qcGrade">
        <rdfs:label>qcGrade</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Harvestlot"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/qualitycheck_checkId">
        <rdfs:label>checkId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/qualitycheck_stage">
        <rdfs:label>stage</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Qualitycheck"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
        <ont:propertyType>integer</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/shipment_shipmentId">
        <rdfs:label>shipmentId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/shipment_modality">
        <rdfs:label>modality</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Shipment"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/coldchainsensor_sensorId">
        <rdfs:label>sensorId</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
        <ont:propertyType>string</ont:propertyType>
    </owl:DatatypeProperty>
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/coldchainsensor_temperatureC">
        <rdfs:label>temperatureC</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Coldchainsensor"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
        <ont:unit>°C</ont:unit>
        <ont:propertyType>decimal</ont:propertyType>
    </owl:DatatypeProperty>

    <!-- RetailDC properties -->
    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/retaildc_dcId">
