    <owl:DatatypeProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/order_deliveryDate">
        <rdfs:label>deliveryDate</rdfs:label>
        <rdfs:domain rdf:resource="http://example.org/ontology/zava-grove-to-shelf-step-4/Order"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
