    <!-- Object Properties (cumulative) -->

    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/grower-owns-farm">
        <rdfs:label>GrowerOwnsFarm</rdfs:label>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>grower</ont:fromEntityId>
        <ont:toEntityId>farm</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/farm-contains-plot">
        <rdfs:label>FarmContainsPlot</rdfs:label>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>farm</ont:fromEntityId>
        <ont:toEntityId>plot</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/plot-grows-fruitvariety">
        <rdfs:label>PlotGrowsFruitVariety</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>plot</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/harvestlot-fromplot-plot">
        <rdfs:label>HarvestLotFromPlot</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>harvestlot</ont:fromEntityId>
        <ont:toEntityId>plot</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/harvestlot-ofvariety-fruitvariety">
        <rdfs:label>HarvestLotOfVariety</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>harvestlot</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/qualitycheck-checks-harvestlot">
        <rdfs:label>QualityCheckChecksHarvestLot</rdfs:label>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>qualitycheck</ont:fromEntityId>
        <ont:toEntityId>harvestlot</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/shipment-carries-harvestlot">
        <rdfs:label>ShipmentCarriesHarvestLot</rdfs:label>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>harvestlot</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/shipment-monitoredby-coldchainsensor">
        <rdfs:label>ShipmentMonitoredBySensor</rdfs:label>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>coldchainsensor</ont:toEntityId>
    </owl:ObjectProperty>

    <!-- New in step 4 -->
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/shipment-deliveredto-retaildc">
        <rdfs:label>ShipmentDeliveredToRetailDC</rdfs:label>
        <rdfs:comment>A shipment is delivered to one retail DC</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>shipment</ont:fromEntityId>
        <ont:toEntityId>retaildc</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/retaildc-supplies-store">
        <rdfs:label>RetailDCSuppliesStore</rdfs:label>
        <rdfs:comment>A DC supplies many retailer stores</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>retaildc</ont:fromEntityId>
        <ont:toEntityId>store</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/store-places-order">
        <rdfs:label>StorePlacesOrder</rdfs:label>
        <rdfs:comment>A store places one or more orders</rdfs:comment>
        <ont:cardinality>one-to-many</ont:cardinality>
        <ont:fromEntityId>store</ont:fromEntityId>
        <ont:toEntityId>order</ont:toEntityId>
    </owl:ObjectProperty>
    <owl:ObjectProperty rdf:about="http://example.org/ontology/zava-grove-to-shelf-step-4/order-forvariety-fruitvariety">
        <rdfs:label>OrderForVariety</rdfs:label>
        <rdfs:comment>Each order is for a specific fruit variety</rdfs:comment>
        <ont:cardinality>many-to-one</ont:cardinality>
        <ont:fromEntityId>order</ont:fromEntityId>
        <ont:toEntityId>fruitvariety</ont:toEntityId>
    </owl:ObjectProperty>

</rdf:RDF>
