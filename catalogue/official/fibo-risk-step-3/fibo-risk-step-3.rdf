<rdf:RDF
    xml:base="http://example.org/ontology/fibo-risk-step-3/"
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
    xmlns:ont="http://example.org/ontology/fibo-risk-step-3/">

  <owl:Ontology rdf:about="">
    <rdfs:label>FIBO Risk Lab — Step 3</rdfs:label>
    <rdfs:comment>Industry classification, geographic hierarchy, and loan classification with Basel risk weights. Adapted from EDM Council FIBO. Source: https://github.com/edmcouncil/fibo — MIT License.</rdfs:comment>
  </owl:Ontology>

  <!-- Step 1: Industry Classification -->
  <owl:Class rdf:about="Sector">
    <rdfs:label>Sector</rdfs:label>
    <rdfs:comment>Top-level economic sector grouping industries by broad function.</rdfs:comment>
    <ont:icon>🏢</ont:icon>
    <ont:color>#0078D4</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Subsector">
    <rdfs:label>Subsector</rdfs:label>
    <rdfs:comment>Subdivision of an economic sector for finer-grained classification.</rdfs:comment>
    <ont:icon>🏗️</ont:icon>
    <ont:color>#00A9E0</ont:color>
  </owl:Class>

  <owl:Class rdf:about="IndustryGroup">
    <rdfs:label>IndustryGroup</rdfs:label>
    <rdfs:comment>NAICS-coded industry group with climate sensitivity and cyclicality attributes for risk analysis.</rdfs:comment>
    <ont:icon>🏭</ont:icon>
    <ont:color>#486991</ont:color>
  </owl:Class>

  <!-- Step 2: Geographic Hierarchy -->
  <owl:Class rdf:about="Region">
    <rdfs:label>Region</rdfs:label>
    <rdfs:comment>Continental or geographic region grouping for macroeconomic analysis.</rdfs:comment>
    <ont:icon>🌍</ont:icon>
    <ont:color>#107C10</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Country">
    <rdfs:label>Country</rdfs:label>
    <rdfs:comment>Nation-state with economic zone, currency, and regulatory framework attributes.</rdfs:comment>
    <ont:icon>🏳️</ont:icon>
    <ont:color>#008272</ont:color>
  </owl:Class>

  <owl:Class rdf:about="Jurisdiction">
    <rdfs:label>Jurisdiction</rdfs:label>
    <rdfs:comment>Subnational jurisdiction with disaster-zone flags for hurricane, flood, earthquake, and wildfire risk.</rdfs:comment>
    <ont:icon>📍</ont:icon>
    <ont:color>#00B294</ont:color>
  </owl:Class>

  <!-- New in Step 3: Loan Classification -->
  <owl:Class rdf:about="ConcentrationCategory">
    <rdfs:label>ConcentrationCategory</rdfs:label>
    <rdfs:comment>Regulatory concentration bucket defined by OCC/FDIC guidance for portfolio risk management.</rdfs:comment>
    <ont:icon>📊</ont:icon>
    <ont:color>#D83B01</ont:color>
  </owl:Class>

  <owl:Class rdf:about="LoanType">
    <rdfs:label>LoanType</rdfs:label>
    <rdfs:comment>Loan product classification with Basel III risk weight, regulatory treatment, and capital tier.</rdfs:comment>
    <ont:icon>💰</ont:icon>
    <ont:color>#E81123</ont:color>
  </owl:Class>

  <owl:Class rdf:about="CollateralType">
    <rdfs:label>CollateralType</rdfs:label>
    <rdfs:comment>Collateral asset category with recovery expectations and concentration classification.</rdfs:comment>
    <ont:icon>🏠</ont:icon>
    <ont:color>#FF8C00</ont:color>
  </owl:Class>

  <!-- Step 1 Properties -->
  <owl:DatatypeProperty rdf:about="sectorCode">
    <rdfs:label>sectorCode</rdfs:label>
    <rdfs:domain rdf:resource="Sector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="sectorName">
    <rdfs:label>sectorName</rdfs:label>
    <rdfs:domain rdf:resource="Sector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="sectorDescription">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="Sector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="subsectorCode">
    <rdfs:label>subsectorCode</rdfs:label>
    <rdfs:domain rdf:resource="Subsector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="subsectorName">
    <rdfs:label>subsectorName</rdfs:label>
    <rdfs:domain rdf:resource="Subsector"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="naicsCode">
    <rdfs:label>naicsCode</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="industryName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="cyclicality">
    <rdfs:label>cyclicality</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="climateSensitivity">
    <rdfs:label>climateSensitivity</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="essentialServices">
    <rdfs:label>essentialServices</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="industryDescription">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- Step 2 Properties -->
  <owl:DatatypeProperty rdf:about="regionCode">
    <rdfs:label>regionCode</rdfs:label>
    <rdfs:domain rdf:resource="Region"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="regionName">
    <rdfs:label>regionName</rdfs:label>
    <rdfs:domain rdf:resource="Region"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="regionDescription">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="Region"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="disasterProfile">
    <rdfs:label>disasterProfile</rdfs:label>
    <rdfs:domain rdf:resource="Region"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="countryCode">
    <rdfs:label>countryCode</rdfs:label>
    <rdfs:domain rdf:resource="Country"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="countryName">
    <rdfs:label>countryName</rdfs:label>
    <rdfs:domain rdf:resource="Country"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="economicZone">
    <rdfs:label>economicZone</rdfs:label>
    <rdfs:domain rdf:resource="Country"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="currency">
    <rdfs:label>currency</rdfs:label>
    <rdfs:domain rdf:resource="Country"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="regulatoryFramework">
    <rdfs:label>regulatoryFramework</rdfs:label>
    <rdfs:domain rdf:resource="Country"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="jurisdictionCode">
    <rdfs:label>code</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="jurisdictionName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="hurricaneZone">
    <rdfs:label>hurricaneZone</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="floodZone">
    <rdfs:label>floodZone</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="earthquakeZone">
    <rdfs:label>earthquakeZone</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="wildfireZone">
    <rdfs:label>wildfireZone</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="coastal">
    <rdfs:label>coastal</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    <ont:propertyType>boolean</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="latitude">
    <rdfs:label>latitude</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="longitude">
    <rdfs:label>longitude</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- New Step 3 Properties -->
  <owl:DatatypeProperty rdf:about="categoryId">
    <rdfs:label>categoryId</rdfs:label>
    <rdfs:domain rdf:resource="ConcentrationCategory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="categoryName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="ConcentrationCategory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="categoryDescription">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="ConcentrationCategory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="occGuidance">
    <rdfs:label>occGuidance</rdfs:label>
    <rdfs:domain rdf:resource="ConcentrationCategory"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="loanTypeCode">
    <rdfs:label>loanTypeCode</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="loanTypeName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="baselRiskWeight">
    <rdfs:label>baselRiskWeight</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#decimal"/>
    <ont:propertyType>decimal</ont:propertyType>
    <ont:unit>%</ont:unit>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="regulatoryTreatment">
    <rdfs:label>regulatoryTreatment</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="capitalTier">
    <rdfs:label>capitalTier</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="loanTypeDescription">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="collateralTypeCode">
    <rdfs:label>collateralTypeCode</rdfs:label>
    <rdfs:domain rdf:resource="CollateralType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
    <ont:isIdentifier rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</ont:isIdentifier>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="collateralTypeName">
    <rdfs:label>name</rdfs:label>
    <rdfs:domain rdf:resource="CollateralType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="recoveryExpectation">
    <rdfs:label>recoveryExpectation</rdfs:label>
    <rdfs:domain rdf:resource="CollateralType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <owl:DatatypeProperty rdf:about="collateralTypeDescription">
    <rdfs:label>description</rdfs:label>
    <rdfs:domain rdf:resource="CollateralType"/>
    <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    <ont:propertyType>string</ont:propertyType>
  </owl:DatatypeProperty>

  <!-- Step 1 Relationships -->
  <owl:ObjectProperty rdf:about="partOfSector">
    <rdfs:label>partOfSector</rdfs:label>
    <rdfs:domain rdf:resource="Subsector"/>
    <rdfs:range rdf:resource="Sector"/>
    <rdfs:comment>Links a subsector to its parent economic sector.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>Subsector</ont:fromEntityId>
    <ont:toEntityId>Sector</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="belongsToSubsector">
    <rdfs:label>belongsToSubsector</rdfs:label>
    <rdfs:domain rdf:resource="IndustryGroup"/>
    <rdfs:range rdf:resource="Subsector"/>
    <rdfs:comment>Links an industry group to its parent subsector.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>IndustryGroup</ont:fromEntityId>
    <ont:toEntityId>Subsector</ont:toEntityId>
  </owl:ObjectProperty>

  <!-- Step 2 Relationships -->
  <owl:ObjectProperty rdf:about="inCountry">
    <rdfs:label>inCountry</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="Country"/>
    <rdfs:comment>Links a jurisdiction to the country it belongs to.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>Jurisdiction</ont:fromEntityId>
    <ont:toEntityId>Country</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="inRegion">
    <rdfs:label>inRegion</rdfs:label>
    <rdfs:domain rdf:resource="Jurisdiction"/>
    <rdfs:range rdf:resource="Region"/>
    <rdfs:comment>Links a jurisdiction to its geographic region.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>Jurisdiction</ont:fromEntityId>
    <ont:toEntityId>Region</ont:toEntityId>
  </owl:ObjectProperty>

  <!-- New Step 3 Relationships -->
  <owl:ObjectProperty rdf:about="loanClassifiedAs">
    <rdfs:label>loanClassifiedAs</rdfs:label>
    <rdfs:domain rdf:resource="LoanType"/>
    <rdfs:range rdf:resource="ConcentrationCategory"/>
    <rdfs:comment>Classifies a loan type into an OCC/FDIC concentration category.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>LoanType</ont:fromEntityId>
    <ont:toEntityId>ConcentrationCategory</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="collateralClassifiedAs">
    <rdfs:label>collateralClassifiedAs</rdfs:label>
    <rdfs:domain rdf:resource="CollateralType"/>
    <rdfs:range rdf:resource="ConcentrationCategory"/>
    <rdfs:comment>Classifies a collateral type into an OCC/FDIC concentration category.</rdfs:comment>
    <ont:cardinality>many-to-one</ont:cardinality>
    <ont:fromEntityId>CollateralType</ont:fromEntityId>
    <ont:toEntityId>ConcentrationCategory</ont:toEntityId>
  </owl:ObjectProperty>

  <owl:ObjectProperty rdf:about="typicallySecuredBy">
    <rdfs:label>typicallySecuredBy</rdfs:label>
    <rdfs:domain rdf:resource="CollateralType"/>
    <rdfs:range rdf:resource="LoanType"/>
    <rdfs:comment>Links a collateral type to the loan types it typically secures.</rdfs:comment>
    <ont:cardinality>many-to-many</ont:cardinality>
    <ont:fromEntityId>CollateralType</ont:fromEntityId>
    <ont:toEntityId>LoanType</ont:toEntityId>
  </owl:ObjectProperty>

</rdf:RDF>
